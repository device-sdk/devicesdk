{
  "$schema": "./node_modules/wrangler/config-schema.json",
  "name": "devicesdk-website",
  "compatibility_date": "2025-12-01",
  "account_id": "888e736867edd3b81b49b17c9067d5df",
  "workers_dev": false,
  "preview_urls": false,
  "assets": {
    "directory": "./public"
  },
  "build": {
    "command": "pnpm run build"
  },
  "routes": [
    {
      "pattern": "devicesdk.com",
      "custom_domain": true
    }
  ]
}
