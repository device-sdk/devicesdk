{
	"name": "@devicesdk/cli",
	"version": "0.7.0",
	"description": "CLI for building, deploying, and flashing DeviceSDK IoT projects.",
	"author": "DeviceSDK <hello@devicesdk.com>",
	"license": "AGPL-3.0-only",
	"homepage": "https://devicesdk.com/docs/",
	"bugs": {
		"url": "https://github.com/device-sdk/devicesdk-monorepo/issues"
	},
	"keywords": [
		"cli",
		"iot",
		"typescript",
		"devicesdk",
		"deploy",
		"flash",
		"firmware",
		"microcontroller",
		"pico",
		"esp32",
		"raspberry-pi-pico",
		"home-assistant",
		"over-the-air",
		"ota",
		"webhook",
		"serverless",
		"cli-tool",
		"arduino-alternative"
	],
	"main": "dist/index.js",
	"bin": {
		"devicesdk": "dist/index.js"
	},
	"files": [
		"dist",
		"LICENSE",
		"README.md"
	],
	"private": false,
	"repository": {
		"type": "git",
		"url": "git+https://github.com/device-sdk/devicesdk-monorepo.git",
		"directory": "packages/cli"
	},
	"type": "module",
	"scripts": {
		"build": "rm -rf dist/ && tsc && pnpm run copy-assets",
		"copy-assets": "cp -r ../../apps/simulation/dist dist/simulator/assets/",
		"start": "tsx src/index.ts",
		"dev": "tsx src/index.ts",
		"test": "tsc && vitest run",
		"test:coverage": "tsc && vitest run --coverage",
		"check-types": "tsc --noEmit",
		"clean": "rm -rf dist"
	},
	"dependencies": {
		"@devicesdk/core": "workspace:*",
		"chokidar": "^3.5.3",
		"commander": "^12.0.0",
		"esbuild": "^0.25.9",
		"execa": "^8.0.1",
		"open": "^10.1.0",
		"ora": "^8.0.1",
		"workerd": "^1.20250831.0",
		"ws": "^8.18.0",
		"zod": "catalog:zod4"
	},
	"devDependencies": {
		"@devicesdk/simulation": "workspace:*",
		"@repo/typescript-config": "workspace:*",
		"@types/node": "catalog:",
		"@types/ws": "^8.5.12",
		"@vitest/coverage-istanbul": "catalog:",
		"ts-node": "^10.9.2",
		"tsx": "catalog:",
		"typescript": "catalog:",
		"vitest": "catalog:"
	}
}
