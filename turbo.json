{
	"$schema": "https://turborepo.com/schema.json",
	"ui": "tui",
	"tasks": {
		"build": {
			"dependsOn": ["^build"],
			"inputs": ["$TURBO_DEFAULT$", ".env*"],
			"outputs": [
				"dist/**",
				".next/**",
				"out/**",
				".quasar/**",
				"build/**",
				"public/**"
			]
		},
		"@devicesdk/server#build": {
			"dependsOn": ["^build"],
			"inputs": ["$TURBO_DEFAULT$", ".env*"],
			"outputs": ["openapi.json"]
		},
		"@devicesdk/website#build": {
			"dependsOn": ["^build", "@devicesdk/server#build"],
			"inputs": ["$TURBO_DEFAULT$", ".env*"],
			"outputs": ["dist/**", "public/**"]
		},
		"dev": { "cache": false, "persistent": true },
		"lint": {},
		"test": { "dependsOn": ["^build"], "cache": false },
		"check-types": { "dependsOn": ["^build"] },
		"deploy": { "dependsOn": ["build"], "cache": false },
		"clean": { "cache": false }
	}
}
