{
	"name": "@devicesdk/server",
	"version": "0.2.0",
	"description": "Self-hosted DeviceSDK server (Bun): REST API, device WebSockets, dashboard hosting",
	"type": "module",
	"private": true,
	"scripts": {
		"dev": "bun run --watch src/server.ts",
		"start": "bun run src/server.ts",
		"openapi": "bun run scripts/generate-openapi.ts",
		"build": "pnpm run openapi",
		"check-types": "tsc --noEmit",
		"test": "bun test src",
		"test:e2e": "bun test src tests",
		"test:coverage": "bun run scripts/coverage-gate.ts",
		"lint": "biome check src tests",
		"lint:fix": "biome check --write src tests",
		"clean": "rm -rf dist openapi.json"
	},
	"dependencies": {
		"@devicesdk/core": "workspace:*",
		"chanfana": "3.3.0",
		"hono": "^4.12.23",
		"workers-qb": "^1.11.2",
		"zod": "catalog:zod4"
	},
	"devDependencies": {
		"@types/bun": "^1.3.5",
		"typescript": "catalog:"
	},
	"license": "AGPL-3.0-only"
}
