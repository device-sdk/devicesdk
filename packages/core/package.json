{
	"name": "@devicesdk/core",
	"version": "1.2.1",
	"description": "Core TypeScript types and device abstractions for DeviceSDK IoT applications.",
	"author": "DeviceSDK <hello@devicesdk.com>",
	"license": "SEE LICENSE IN LICENSE",
	"homepage": "https://devicesdk.com",
	"bugs": {
		"url": "https://github.com/device-sdk/devicesdk-monorepo/issues"
	},
	"keywords": [
		"iot",
		"typescript",
		"devicesdk",
		"microcontroller",
		"pico",
		"esp32"
	],
	"main": "dist/index.js",
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"import": "./dist/index.js"
		},
		"./i2c": {
			"types": "./dist/i2c/index.d.ts",
			"import": "./dist/i2c/index.js"
		},
		"./devices/pico": {
			"types": "./dist/devices/pico.d.ts",
			"import": "./dist/devices/pico.js"
		},
		"./package.json": "./package.json"
	},
	"files": [
		"dist",
		"LICENSE",
		"README.md"
	],
	"private": false,
	"repository": {
		"type": "git",
		"url": "git+https://github.com/device-sdk/devicesdk-monorepo.git",
		"directory": "packages/core"
	},
	"type": "module",
	"scripts": {
		"build": "tsc",
		"check-types": "tsc --noEmit",
		"clean": "rm -rf dist"
	},
	"dependencies": {},
	"devDependencies": {
		"@repo/typescript-config": "workspace:*",
		"tsx": "catalog:",
		"typescript": "catalog:"
	}
}
