# Cloudflare Static Assets redirects
# Format: <from> <to> <status>
# See apps/website/AGENTS.md "URL changes require a redirect" - every move/rename
# of a content file MUST add an entry here so we don't lose Google index signal.

/docs/resources/hardware/         /docs/hardware/        301
/docs/resources/hardware/:slug    /docs/hardware/:slug   301
/docs/resources/changelog/        /docs/changelog/       301
/docs/guides/control-from-browser/ /docs/guides/         301
/docs                              /docs/                301

# Self-host pivot: pages removed when DeviceSDK became free, open-source, and
# self-hosted (no managed cloud, no pricing, no private beta).
/pricing/                          /                      301
/early-access/                     /docs/quickstart/      301

# Removed error pages (account suspension and deletion-grace no longer exist).
/docs/errors/account_suspended/         /docs/errors/     301
/docs/errors/account_deletion_pending/  /docs/errors/     301
