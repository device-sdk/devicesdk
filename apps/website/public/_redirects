# of a content file MUST add an entry here so we don't lose Google index signal.

/docs/resources/hardware/         /docs/hardware/        301
/docs/resources/hardware/:slug    /docs/hardware/:slug   301
/docs/resources/changelog/        /docs/changelog/       301
/docs/guides/control-from-browser/ /docs/guides/         301
/docs                              /docs/                301
