{
	"name": "@devicesdk/core",
	"version": "1.4.2",
	"description": "Core TypeScript types and device abstractions for DeviceSDK IoT applications.",
	"author": "DeviceSDK <hello@devicesdk.com>",
	"license": "AGPL-3.0-only",
	"homepage": "https://devicesdk.com/docs/",
	"bugs": {
		"url": "https://github.com/device-sdk/devicesdk-monorepo/issues"
	},
	"keywords": [
		"iot",
		"typescript",
		"devicesdk",
		"microcontroller",
		"pico",
		"esp32",
		"esp32-c3",
		"esp32-c61",
		"raspberry-pi-pico",
		"rp2040",
		"rp2350",
		"gpio",
		"i2c",
		"spi",
		"uart",
		"pwm",
		"adc",
		"oled",
		"ws2812",
		"neopixel",
		"home-assistant",
		"over-the-air",
		"ota",
		"webhook",
		"serverless",
		"edge",
		"firmware",
		"arduino-alternative"
	],
	"main": "dist/index.js",
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"import": "./dist/index.js"
		},
		"./i2c": {
			"types": "./dist/i2c/index.d.ts",
			"import": "./dist/i2c/index.js"
		},
		"./devices/pico": {
			"types": "./dist/devices/pico.d.ts",
			"import": "./dist/devices/pico.js"
		},
		"./devices/esp32": {
			"types": "./dist/devices/esp32.d.ts",
			"import": "./dist/devices/esp32.js"
		},
		"./package.json": "./package.json"
	},
	"files": [
		"dist",
		"docs",
		"AGENTS.md",
		"LICENSE",
		"README.md"
	],
	"private": false,
	"repository": {
		"type": "git",
		"url": "git+https://github.com/device-sdk/devicesdk-monorepo.git",
		"directory": "packages/core"
	},
	"type": "module",
	"scripts": {
		"build": "tsc",
		"check-types": "tsc --noEmit && tsc --noEmit -p tests/tsconfig.json",
		"test": "vitest run --config vitest.config.ts",
		"clean": "rm -rf dist"
	},
	"dependencies": {},
	"devDependencies": {
		"@repo/typescript-config": "workspace:*",
		"tsx": "catalog:",
		"typescript": "catalog:",
		"vitest": "catalog:"
	}
}
