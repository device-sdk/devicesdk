# Dependencies
node_modules/

# Turbo
.turbo/

# Build outputs
dist/
.next/
out/
.quasar/
build/

# Server runtime data (SQLite DB, scripts, firmwares)
data/
data-*/

# Test coverage reports
coverage/

# Cloudflare
.wrangler/
.dev.vars

# Generated website assets
apps/website/.vite-ssg-temp/
apps/website/src/generated/
apps/website/static/og-images/
apps/website/static/docs/api/
apps/website/static/.well-known/agent-skills/
apps/website/static/**/*.md
apps/website/static/llms.txt
apps/website/static/llms-full.txt
apps/website/static/sitemap.xml

# Plans and specs (local drafts)
docs/plans/
docs/superpowers/specs/

# Firmware builds
firmware/esp32/build/
firmware/esp32/build.*/
firmware/pico/build/

# ESP-IDF leftovers (renamed sdkconfig from `idf.py set-target`)
firmware/esp32/sdkconfig.old

# ESP-IDF managed components and Python cache
firmware/esp32/managed_components/
__pycache__/

# Python virtual environments (created by firmware-esp32 CI workflow)
.venv/
venv/

# IDE files
.idea/
.vscode/
*.suo
*.ntvs*
*.njsproj
*.sln

# OS files
.DS_Store
.thumbs.db

# Environment files
.env
.env.local*
*.local

# Old lock files (pnpm-lock.yaml is the only lock file)
package-lock.json
yarn.lock

# Logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# DeviceSDK CLI
.devicesdk/

# Simulator assets are built from apps/simulation — biome skips this broken symlink in CI
packages/cli/src/simulator/assets

# Quasar
/quasar.config.*.temporary.compiled*

.claude/worktrees/
.claude/scheduled_tasks.lock
.worktrees/

# Sensitive: never commit downloaded OAuth client secret JSONs
client_secret*.json

# Certificates and private keys
*.pem
*.key
*.p12
*.pfx
