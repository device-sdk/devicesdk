{
	"compilerOptions": {
		"target": "ES2022",
		"module": "ESNext",
		"moduleResolution": "bundler",
		"strict": true,
		"noEmit": true,
		"lib": ["ES2022", "DOM", "DOM.Iterable"],
		"jsx": "preserve",
		"resolveJsonModule": true,
		"isolatedModules": true,
		"skipLibCheck": true,
		"paths": { "@/*": ["./src/*"] }
	},
	"include": ["src/**/*.ts", "src/**/*.vue", "vite-env.d.ts"],
	"exclude": ["node_modules"]
}
