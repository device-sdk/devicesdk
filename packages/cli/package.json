{
	"name": "@devicesdk/cli",
	"version": "0.0.2",
	"description": "CLI tool for developing and deploying DeviceSDK IoT applications.",
	"author": "",
	"main": "dist/index.js",
	"bin": {
		"devicesdk": "dist/index.js"
	},
	"files": [
		"dist",
		"LICENSE",
		"README.md"
	],
	"private": false,
	"repository": {
		"type": "git",
		"url": "git+https://github.com/device-sdk/devicesdk-monorepo.git",
		"directory": "packages/cli"
	},
	"publishConfig": {
		"provenance": true
	},
	"type": "module",
	"scripts": {
		"build": "rm -rf dist/ && tsc && pnpm run copy-assets",
		"copy-assets": "cp -r ../../apps/simulation/dist dist/simulator/assets/",
		"start": "tsx src/index.ts",
		"dev": "tsx src/index.ts",
		"test": "tsc && vitest",
		"check-types": "tsc --noEmit",
		"clean": "rm -rf dist"
	},
	"dependencies": {
		"chokidar": "^3.5.3",
		"commander": "^12.0.0",
		"esbuild": "^0.25.9",
		"execa": "^8.0.1",
		"open": "^10.1.0",
		"ora": "^8.0.1",
		"workerd": "^1.20250831.0",
		"zod": "catalog:zod4"
	},
	"devDependencies": {
		"@devicesdk/simulation": "workspace:*",
		"@repo/typescript-config": "workspace:*",
		"@types/node": "catalog:",
		"ts-node": "^10.9.2",
		"tsx": "catalog:",
		"typescript": "catalog:",
		"vitest": "catalog:"
	}
}
