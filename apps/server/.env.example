# DeviceSDK server environment variables.
# Copy this file to .env and adjust values for your self-hosted install.
# All variables are optional; sensible defaults are shown below.

# HTTP port for the REST API, device WebSockets, watcher stream, and dashboard SPA.
PORT=8080

# Root directory for all persistent state: SQLite DB, device scripts, firmware images.
# In Docker this defaults to /data; outside Docker it defaults to ./data.
DATA_DIR=./data

# Set to "local" when running the dashboard Quasar dev server on localhost:9000
# (enables CORS and other dev-friendly behavior). Otherwise leave as "production".
ENV=production

# Allow new account registration. The first registered user is always allowed;
# set this to false after creating your admin account to close sign-ups.
ALLOW_REGISTRATION=true

# Set to true when serving behind an HTTPS reverse proxy so session cookies
# get the Secure flag. Leave false for plain-HTTP LAN use.
SECURE_COOKIES=false

# Path to the built dashboard SPA to serve at /. Leave empty during local server
# development if you run the dashboard separately on port 9000.
# PUBLIC_DIR=./apps/dashboard/dist/spa

# Directory containing bundled firmware binaries used to seed DATA_DIR on first boot.
# The Docker image sets this automatically; usually no need to change it.
# FIRMWARES_DIST_DIR=

# Advertise this server over mDNS as <MDNS_HOSTNAME>.local so devices can find it
# without a static LAN IP. Disable if you run multiple servers or don't need it.
MDNS_ENABLED=true
MDNS_HOSTNAME=devicesdk

# Trust X-Forwarded-For / X-Real-IP headers when the server is behind a reverse
# proxy. Leave false (default) for direct LAN exposure so clients can't spoof IPs.
TRUST_PROXY=false

# Override the migrations directory. The Docker image uses this because the bundled
# server.js is no longer next to the migrations folder.
# MIGRATIONS_DIR=./apps/server/migrations
