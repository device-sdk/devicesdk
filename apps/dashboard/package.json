{
  "name": "@devicesdk/dashboard",
  "version": "0.2.0",
  "description": "DeviceSDK Control Panel",
  "productName": "DeviceSDK",
  "author": "Gabriel Massadas <gmassadas@cloudflare.com>",
  "type": "module",
  "private": true,
  "scripts": {
    "lint": "eslint -c ./eslint.config.js \"./src*/**/*.{ts,js,cjs,mjs,vue}\"",
    "format": "prettier --write \"**/*.{js,ts,vue,scss,html,md,json}\" --ignore-path .gitignore",
    "test": "pnpm test:unit && pnpm test:e2e",
    "test:unit": "vitest run --config tests/unit/vitest.config.ts",
    "test:e2e": "playwright test --config tests/e2e/playwright.config.ts",
    "dev": "quasar dev",
    "build": "quasar build",
    "postinstall": "quasar prepare",
    "check-types": "vue-tsc --noEmit",
    "deploy": "wrangler pages deploy",
    "clean": "rm -rf dist .quasar"
  },
  "dependencies": {
    "@quasar/extras": "^1.16.4",
    "echarts": "^5.6.0",
    "pinia": "^3.0.1",
    "quasar": "^2.16.0",
    "vue": "^3.5.22",
    "vue-echarts": "^7.0.3",
    "vue-router": "^4.0.12"
  },
  "devDependencies": {
    "@eslint/js": "^9.14.0",
    "@playwright/test": "^1.58.2",
    "@quasar/app-vite": "^2.1.0",
    "@quasar/quasar-app-extension-testing-unit-vitest": "^1.2.4",
    "@types/node": "catalog:",
    "@vitejs/plugin-vue": "^5.2.4",
    "@vitest/coverage-istanbul": "catalog:",
    "@vue/eslint-config-prettier": "^10.1.0",
    "@vue/eslint-config-typescript": "^14.4.0",
    "@vue/test-utils": "^2.4.6",
    "autoprefixer": "^10.4.2",
    "eslint": "^9.14.0",
    "eslint-plugin-vue": "^10.4.0",
    "globals": "^16.4.0",
    "jsdom": "^28.1.0",
    "prettier": "^3.3.3",
    "typescript": "catalog:",
    "vite-plugin-checker": "^0.11.0",
    "vitest": "catalog:",
    "vue-eslint-parser": "^10.2.0",
    "vue-tsc": "^3.0.7",
    "wrangler": "catalog:"
  },
  "engines": {
    "node": "^28 || ^26 || ^24 || ^22 || ^20",
    "npm": ">= 6.13.4",
    "yarn": ">= 1.21.1"
  }
}
