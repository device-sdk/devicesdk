{
	"name": "@devicesdk/api",
	"version": "0.2.11",
	"description": "",
	"type": "module",
	"private": true,
	"scripts": {
		"deploy": "wrangler deploy",
		"dev": "wrangler dev",
		"openapi": "npx chanfana -o openapi.json --port 8989 --var ENV:local",
		"build": "pnpm run openapi",
		"test": "tsc && npx vitest run --config tests/vitest.unit.config.mts && npx vitest run --config tests/vitest.config.mts",
		"test:unit": "npx vitest run --config tests/vitest.unit.config.mts",
		"test:coverage": "tsc && npx vitest run --config tests/vitest.config.mts --coverage",
		"check-types": "tsc --noEmit",
		"clean": "rm -rf dist openapi.json",
		"db:pull": "npx wrangler d1 export iotkit-users --remote --output .wrangler/d1-remote-dump.sql && rm -rf .wrangler/state/v3/d1 && npx wrangler d1 execute DB --local --file .wrangler/d1-remote-dump.sql && rm .wrangler/d1-remote-dump.sql"
	},
	"dependencies": {
		"@devicesdk/core": "workspace:*",
		"@hono/oauth-providers": "^0.8.5",
		"@sentry/cloudflare": "^10.29.0",
		"chanfana": "^3.3.0",
		"hono": "4.10.7",
		"workers-qb": "^1.11.2",
		"zod": "catalog:zod4"
	},
	"devDependencies": {
		"@cloudflare/vitest-pool-workers": "^0.15.2",
		"@cloudflare/workers-types": "^4.20260501.1",
		"@types/node": "catalog:",
		"@vitest/coverage-istanbul": "catalog:",
		"@vitest/runner": "catalog:",
		"@vitest/snapshot": "catalog:",
		"typescript": "catalog:",
		"vitest": "catalog:",
		"wrangler": "catalog:"
	}
}
